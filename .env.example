# Copy to .env.local and fill in values (Vite loads .env.local in dev).
# Get Supabase URL and publishable key from: Project Settings → API.

# Supabase project URL (Realtime only on the client; data goes through the API).
VITE_SUPABASE_URL=https://your-project.supabase.co

# Publishable (anon) key — safe for the browser; used only for Realtime subscriptions.
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Express API base URL (optional; default is http://localhost:3000).
# VITE_API_URL=http://localhost:3000
