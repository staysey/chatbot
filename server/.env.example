# Copy to server/.env and fill in values.
# Never commit server/.env or share service role / Gemini keys.

# Google Gemini API key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Supabase project URL (Project Settings → API)
SUPABASE_URL=https://your-project.supabase.co

# Service role key — server only; bypasses RLS. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# Where Supabase sends users after email confirmation (optional)
# AUTH_REDIRECT_URL=http://localhost:8100/login
